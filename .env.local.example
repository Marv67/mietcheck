# Kopiere diese Datei nach .env.local und trage die Werte ein.
# .env.local ist gitignored — niemals echte Keys committen.

# ── Anthropic (Klausel-Analyse) ──
# Ohne Key laeuft /api/analyze im Mock-Modus (statische Sample-Ergebnisse).
ANTHROPIC_API_KEY=
# Optionaler Modell-Override (Default: claude-sonnet-4-5)
# ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Stripe (Bezahlung der Vollanalyse, 2,99 EUR) ──
# Secret Key (sk_test_... im Test, sk_live_... in Produktion). Nur serverseitig.
STRIPE_SECRET_KEY=

# ── Report-Verschluesselung (Bezahl-Schutz) ──
# Schluessel zum Ver-/Entschluesseln der bezahlpflichtigen Report-Details.
# Beliebiger Zufallswert, mind. 16 Zeichen — erzeugen mit: openssl rand -hex 32
# PFLICHT in Produktion: ohne diesen Wert schlaegt /api/analyze fail-closed fehl.
UNLOCK_SECRET=

# ── Basis-URL fuer Stripe-Redirects ──
# Optional. Fehlt der Wert, wird der Request-Host genutzt. In Produktion
# (Vercel) auf die echte Domain setzen, z. B. https://klaremiete.de
# NEXT_PUBLIC_SITE_URL=
